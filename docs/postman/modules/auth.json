          "raw": "{\n    \"invitationToken\": \"a3f2b9c1-4d5e-6f7g-8h9i-0j1k2l3m4n5o\",\n    \"email\": \"worker@example.com\",\n    \"name\": \"John Doe\",\n    \"username\": \"johndoe\",\n    \"password\": \"password123\"\n}"
