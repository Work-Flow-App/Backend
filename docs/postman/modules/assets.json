    {
      "name": "Get Asset Statistics",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{jwt_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/assets/statistics",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "assets",
            "statistics"
          ]
        },
        "description": "Get asset statistics for the company\n\n**Response:**\n- totalAssets (long): Total number of assets\n- activeAssets (long): Number of active (non-archived) assets\n- archivedAssets (long): Number of archived assets\n- totalValue (BigDecimal): Total purchase value of all assets\n- currentValue (BigDecimal): Current depreciated value of all assets\n- totalDepreciation (BigDecimal): Total depreciation amount\n\n```bash\ncurl -X GET \"{{base_url}}/api/v1/assets/statistics\" \\\n  -H \"Authorization: Bearer {{jwt_token}}\"\n```"
      },
      "response": [
        {
          "name": "Get Asset Statistics - Success",
          "originalRequest": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/assets/statistics",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "assets",
                "statistics"
              ]
            }
          },
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n    \"totalAssets\": 15,\n    \"activeAssets\": 12,\n    \"archivedAssets\": 3,\n    \"totalValue\": 250000.00,\n    \"currentValue\": 180000.00,\n    \"totalDepreciation\": 70000.00\n}"
        }
