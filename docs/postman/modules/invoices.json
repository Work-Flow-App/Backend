{
  "name": "Invoices",
  "description": "Invoice generation and retrieval endpoints. Invoices are generated as PDF documents from selected line items of an estimate and stored in S3. A presigned URL is returned to allow direct PDF download.",
  "item": [
    {
      "name": "Generate Invoice",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{jwt_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"lineItemIds\": [1, 2, 3],\n    \"dueDate\": \"2026-04-30\",\n    \"reference\": \"PO-2026-001\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/estimates/:estimateId/invoice",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "estimates",
            ":estimateId",
            "invoice"
          ],
          "variable": [
            {
              "key": "estimateId",
              "value": "1",
              "description": "The ID of the estimate to generate an invoice for"
            }
