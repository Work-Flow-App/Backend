          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.environment.set(\"jwt_token\", response.accessToken);",
              "    pm.environment.set(\"refresh_token\", response.refreshToken);",
