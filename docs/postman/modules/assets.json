                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "assets"
              ]
            }
          },
          "status": "Created",
          "code": 201,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n    \"id\": 10,\n    \"companyId\": 1,\n    \"name\": \"Company Van A1\",\n    \"assetTag\": \"VAN-001\",\n    \"serialNumber\": \"SN-2025-AX11\",\n    \"purchasePrice\": 30000.00,\n    \"purchaseDate\": \"2023-01-01\",\n    \"depreciationRate\": 20.00,\n    \"salvageValue\": 5000.00,\n    \"available\": true,\n    \"archived\": false,\n    \"createdAt\": \"2025-11-20T10:00:00\",\n    \"updatedAt\": \"2025-11-20T10:00:00\"\n}"
