            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"productCode\": \"SVC-002\",\n    \"unitPrice\": 200.00,\n    \"quantity\": 3.0\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/line-items/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "line-items",
            "1"
          ]
        },
        "description": "Update an existing line item. All fields are optional — only provided fields will be updated. The `netAmount`, `vatAmount`, and `totalAmount` fields are automatically recalculated based on the updated values.\n\n**Optional fields (all):**\n- `productCode` (String): Updated product or service code\n- `productDescription` (String): Updated description\n- `additionalDetails` (String): Updated additional context\n- `unitPrice` (BigDecimal): Updated unit price, must be >= 0\n- `coreOrSub` (String enum): `CORE` or `SUB`\n- `quantity` (BigDecimal): Updated quantity, must be > 0\n- `vatRate` (BigDecimal): Updated VAT rate as a decimal, must be >= 0\n\n**Note:** If this line item is linked to any estimates, those estimates will reflect the updated amounts immediately.\n\n```bash\ncurl -X PUT \"{{base_url}}/api/v1/line-items/1\" \\\n  -H \"Authorization: Bearer {{jwt_token}}\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"productCode\": \"SVC-002\",\n    \"unitPrice\": 200.00,\n    \"quantity\": 3.0\n  }'\n```"
      },
      "response": [
        {
          "name": "Update Line Item - Success",
          "originalRequest": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"productCode\": \"SVC-002\",\n    \"unitPrice\": 200.00,\n    \"quantity\": 3.0\n}"
            },
            "url": {
